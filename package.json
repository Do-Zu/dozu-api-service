{
  "name": "api-services",
  "version": "0.0.1",
  "description": "api service ",
  "main": "index.js",
  "_moduleAliases": {
    "@": "dist"
  },
  "scripts": {
    "dev": "set NODE_ENV=development&& nodemon",
    "start": "set NODE_ENV=production && node dist/index.js",
    "build": "set NODE_ENV=production && tsc",
    "build:watch": "tsc --watch",
    "vercel-build": "npm run build",
    "format": "prettier --write \"src/**/*.ts\"",
    "clean": "rimraf dist",
    "prebuild": "npm run clean",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "generate:api": "node scripts/generate/generate-api.js",
    "db:generate:dev": "set NODE_ENV=development && npx drizzle-kit generate",
    "db:migrate:dev": "set NODE_ENV=development && npx drizzle-kit migrate",
    "db:generate:prod": "set NODE_ENV=production && npx drizzle-kit generate",
    "db:migrate:prod": "set NODE_ENV=production && npx drizzle-kit migrate",
    "db:migrate:docker": "drizzle-kit push:pg --schema ./dist/db/schema.js --out-dir ./src/db/migrations",
    "lambda:clean": "rimraf dist-lambda",
    "lambda:build": "node scripts/build-lambda.js",
    "lambda:package": "node scripts/package-lambda.js",
    "lambda:deploy": "aws lambda update-function-code --function-name handle-gen-content-api-integrate --zip-file fileb://dist-lambda/function.zip",
    "lambda:update-config": "aws lambda update-function-configuration --function-name handle-gen-content-api-integrate --handler index.handler --runtime nodejs20.x --timeout 60",
    "lambda:all": "npm run lambda:clean && npm run lambda:build && npm run lambda:package && npm run lambda:deploy && npm run lambda:update-config"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/aws-lambda": "^8.10.149",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/module-alias": "^2.0.4",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/murmurhash3js": "^3.0.7",
    "@types/node": "^22.14.0",
    "@types/opossum": "^8.1.8",
    "@types/pako": "^2.0.3",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.11.11",
    "drizzle-kit": "^0.30.6",
    "esbuild": "^0.25.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.14.0",
    "nodemon": "^3.1.7",
    "openapi-typescript-codegen": "^0.29.0",
    "prettier": "3.4.2",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.18.2"
  },
  "dependencies": {
    "@aws-sdk/client-lambda": "^3.787.0",
    "aws-lambda": "^1.0.7",
    "bullmq": "^5.49.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.41.0",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.6.1",
    "module-alias": "^2.2.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.2",
    "openai": "^4.93.0",
    "opossum": "^8.4.0",
    "pako": "^2.1.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.14.1",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.3"
  }
}
