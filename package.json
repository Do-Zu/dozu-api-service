{
    "name": "api-services",
    "version": "0.0.1",
    "description": "api service ",
    "main": "index.js",
    "_moduleAliases": {
        "@": "dist"
    },
    "scripts": {
        "dev": "set NODE_ENV=development&& nodemon",
        "start": "set NODE_ENV=production && node dist/index.js",
        "build": "set NODE_ENV=production && tsc",
        "stage": "set NODE_ENV=stage && tsc --outDir dist-stage && node -r tsconfig-paths/register --max-old-space-size=2048 dist-stage/index.js",
        "build:watch": "tsc --watch",
        "vercel-build": "npm run build",
        "format": "prettier --write \"src/**/*.ts\"",
        "clean": "rimraf dist",
        "prebuild": "npm run clean",
        "typecheck": "tsc --noEmit",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "generate:api": "node scripts/generate/generate-api.js",
        "db:generate:dev": "set NODE_ENV=development && npx drizzle-kit generate",
        "db:migrate:dev": "set NODE_ENV=development && npx drizzle-kit migrate",
        "db:generate:prod": "set NODE_ENV=production && npx drizzle-kit generate",
        "db:migrate:prod": "set NODE_ENV=production && npx drizzle-kit migrate",
        "db:migrate:docker": "drizzle-kit push:pg --schema ./dist/db/schema.js --out-dir ./src/db/migrations",
        "lambda:generate:clean": "rimraf dist-lambda",
        "lambda:generate:build": "node scripts/build-lambda.js",
        "lambda:generate:package": "node scripts/package-lambda.js",
        "lambda:generate:deploy:prod": "aws lambda update-function-code --function-name handle-gen-content-api-integrate-product --zip-file fileb://dist-lambda/function.zip",
        "lambda:generate:deploy:dev": "aws lambda update-function-code --function-name handle-gen-content-api-integrate-development --zip-file fileb://dist-lambda/function.zip",
        "lambda:generate:update-config:prod": "aws lambda update-function-configuration --function-name handle-gen-content-api-integrate-product --handler index.handler --runtime nodejs20.x --timeout 300",
        "lambda:generate:update-config:dev": "aws lambda update-function-configuration --function-name handle-gen-content-api-integrate-development --handler index.handler --runtime nodejs20.x --timeout 300",
        "lambda:generate:all:prod": "npm run lambda:generate:clean && npm run lambda:generate:build && npm run lambda:generate:package && npm run lambda:generate:deploy:prod && npm run lambda:generate:update-config:prod",
        "lambda:generate:all:dev": "npm run lambda:generate:clean && npm run lambda:generate:build && npm run lambda:generate:package && npm run lambda:generate:deploy:dev && npm run lambda:generate:update-config:dev",
        "docker:up:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml up -d",
        "docker:down:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml down",
        "docker:build:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml build",
        "docker:logs:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml logs -f postgres",
        "docker:restart:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml restart",
        "docker:clean:db:postgres": "docker-compose -f containers/database/postgres/docker-compose.yml down -v --remove-orphans",
        "docker:whisper:build": "docker build -f containers/whisper/Dockerfile -t whisper-service containers/whisper",
        "docker:whisper:run": "docker run --rm -p 8624:8624 --name whisper-service whisper-service",
        "docker:stress:stage:build": "docker build -t dozu-api-service:stage-stress --build-arg ENV_FILE=.env.stage .",
        "docker:stress:stage:run": "docker run --rm --name dozu-api-service-stress-stage --cpus=2 --memory=2g --memory-swap=2g -p 3555:3555 -e NODE_ENV=stage dozu-api-service:stage-stress node dist/index.js",
        "docker:stress:stage": "npm run docker:stress:stage:build && npm run docker:stress:stage:run"
    },
    "engines": {
        "node": ">=20"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "devDependencies": {
        "@eslint/js": "9.17.0",
        "@types/aws-lambda": "8.10.149",
        "@types/cookie-parser": "1.4.8",
        "@types/cors": "2.8.17",
        "@types/express": "5.0.1",
        "@types/jest": "30.0.0",
        "@types/jsonwebtoken": "9.0.9",
        "@types/module-alias": "2.0.4",
        "@types/morgan": "1.9.9",
        "@types/multer": "1.4.12",
        "@types/murmurhash3js": "3.0.7",
        "@types/node": "22.14.0",
        "@types/nodemailer": "6.4.17",
        "@types/opossum": "8.1.8",
        "@types/pako": "2.0.3",
        "@types/pdf-parse": "1.1.5",
        "@types/pg": "8.11.11",
        "drizzle-kit": "0.30.6",
        "esbuild": "0.25.2",
        "eslint": "9.17.0",
        "eslint-config-prettier": "9.1.0",
        "globals": "15.14.0",
        "jest": "30.1.3",
        "nodemon": "3.1.7",
        "openapi-typescript-codegen": "0.29.0",
        "prettier": "3.4.2",
        "rimraf": "6.0.1",
        "ts-jest": "29.4.3",
        "ts-node": "10.9.1",
        "tsconfig-paths": "4.2.0",
        "tsx": "^4.19.3",
        "typescript": "5.8.3",
        "typescript-eslint": "8.35.0"
    },
    "dependencies": {
        "@aws-sdk/client-lambda": "3.787.0",
        "@aws-sdk/client-s3": "3.864.0",
        "@aws-sdk/s3-request-presigner": "3.864.0",
        "@payos/node": "1.0.10",
        "aws-lambda": "1.0.7",
        "axios": "1.13.2",
        "bullmq": "5.49.1",
        "cloudinary": "2.7.0",
        "cloudinary-build-url": "0.2.4",
        "cookie-parser": "1.4.7",
        "cors": "2.8.5",
        "date-fns": "4.1.0",
        "date-fns-tz": "3.2.0",
        "dotenv": "16.4.7",
        "drizzle-orm": "0.41.0",
        "express": "^4.21.2",
        "express-rate-limit": "7.5.0",
        "express-validator": "7.2.1",
        "form-data": "4.0.5",
        "google-auth-library": "9.15.1",
        "helmet": "8.1.0",
        "ioredis": "5.6.1",
        "jsonwebtoken": "9.0.2",
        "module-alias": "2.2.3",
        "morgan": "1.10.0",
        "multer": "2.0.1",
        "nanoid": "5.1.5",
        "node-cron": "4.2.1",
        "nodemailer": "6.10.1",
        "openai": "4.104.0",
        "opossum": "8.4.0",
        "pako": "2.1.0",
        "pdf-lib": "1.17.1",
        "pdf-parse": "1.1.1",
        "pg": "8.14.1",
        "puppeteer": "24.32.0",
        "sanitize-filename": "1.6.3",
        "socket.io": "4.8.1",
        "unsplash-js": "7.0.19",
        "uuid": "11.1.0",
        "winston": "3.17.0",
        "youtubei.js": "16.0.1",
        "zod": "3.24.3"
    }
}
